# Root env for docker-compose and local dev
# Copy to .env and adjust as needed

# Optional: Slack webhooks for run-epics
# Create Incoming Webhooks at https://api.slack.com/apps → your app → Incoming Webhooks
# SLACK_REVIEW_WEBHOOK_URL=...  (code review results)
# SLACK_PR_WEBHOOK_URL=...      (PR merged notifications)
# SLACK_EPIC_WEBHOOK_URL=...   (epic checklist updates)

# API base URL (used by web app to call API)
# Local (api on host): http://localhost:8000
# Docker: web uses http://api:8000 (internal); from host use http://localhost:8001
API_URL=http://localhost:8000